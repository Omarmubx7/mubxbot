# Azure AD Application Credentials
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id

# HTU Login Credentials
HTU_EMAIL=your-email@htu.edu.jo
HTU_PASSWORD=your-htu-password

# Notification Credentials
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
NOTIFY_EMAIL=alerts@example.com

# Optional session/tokens (prefer short-lived and rotated frequently)
GRAPH_TOKEN=replace-with-short-lived-token
SHAREPOINT_FEDAUTH=replace-with-short-lived-cookie
SHAREPOINT_RTFA=replace-with-short-lived-cookie

# Admin Security
ADMIN_PASSWORD=replace-with-strong-admin-password
ADMIN_SESSION_SECRET=replace-with-long-random-secret
